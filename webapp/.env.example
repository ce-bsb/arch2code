# arch2code webapp — environment template.
#
# Copy to webapp/.env only if you want to override a default; the app reads the
# real process environment, so exporting the variables in your shell works too.
#
# THIS FILE MUST NEVER CONTAIN A VALUE FOR A SECRET. The watsonx credentials
# live in mcp/arch_vision/.env, which is git-ignored and read by the app solely
# to populate the environment of the child processes it spawns. No key is ever
# written to run.json, events.jsonl, an artifact, a log line or an API response.

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------

# Repository root. Everything else is resolved against it. Default: the parent
# directory of webapp/. run.sh exports this explicitly.
ARCH2CODE_PROJECT_ROOT=

# Working directory for every Bob subprocess. LOAD-BEARING: Bob resolves
# --chat-mode from the .bob/custom_modes.yaml of its CWD — 10 chat modes from
# the repo root, only 4 from anywhere else. Point this at a scratch clone if you
# do not want a demo run writing into this repository's .arch/ tree.
# Default: ARCH2CODE_PROJECT_ROOT.
ARCH2CODE_BOB_CWD=

# ---------------------------------------------------------------------------
# Bob CLI
# ---------------------------------------------------------------------------

# How to invoke Bob. Two accepted forms:
#   ARCH2CODE_BOB_BIN=bob                     (an executable on PATH)
#   ARCH2CODE_BOB_BIN="node /abs/path/bob.js" (the bundle)
# A bare path ending in .js is rewritten to `node <path>`. Never run through a
# shell. Default: the `bob` found on PATH; if there is none, the health report
# says so and Mode B is blocked while Mode A keeps working.
ARCH2CODE_BOB_BIN=

# Force the PTY output strategy for Bob subprocesses (1/true/yes/on).
# Why it exists: `--list-sessions` prints 464 bytes under a PTY and 0 bytes
# under a pipe, so at least one Bob output path is conditioned on a TTY. The
# default is the pipe strategy; the app detects "exit 0 with empty stdout" and
# offers a one-click PTY retry. Default: 0.
ARCH2CODE_BOB_PTY=

# Hard ceiling on Bobcoin per stage, passed through as --max-coins. Bob exits 1
# when the ceiling is exceeded. Empty = do not pass the flag.
ARCH2CODE_BOB_MAX_COINS=

# Pass --accept-license (1/0). Default 1: a non-interactive run cannot answer
# the licence prompt, and without this the process exits 1 with an empty stdout.
ARCH2CODE_BOB_ACCEPT_LICENSE=

# Value for --auth-method. Default "api-key". Set empty to omit the flag.
ARCH2CODE_BOB_AUTH_METHOD=

# ---------------------------------------------------------------------------
# Python interpreter for child processes
# ---------------------------------------------------------------------------

# Interpreter used for mcp/arch_vision/server.py and for every deterministic
# helper script. This is a real failure mode: the system python3 here is 3.9.6
# and has neither mcp nor httpx nor pydantic nor Pillow.
# Default: /opt/anaconda3/bin/python
ARCH2CODE_PYTHON=

# ---------------------------------------------------------------------------
# Limits and timeouts
# ---------------------------------------------------------------------------

# Maximum upload size in megabytes. Default 25.
ARCH2CODE_MAX_UPLOAD_MB=

# Wall-clock ceiling for one Bob stage, in seconds. Default 1800.
ARCH2CODE_STAGE_TIMEOUT_S=

# Wall-clock ceiling for one MCP vision call, in seconds. Default 180.
ARCH2CODE_VISION_TIMEOUT_S=

# Seconds between SSE heartbeat comments. Default 15.
ARCH2CODE_SSE_HEARTBEAT_S=

# Concurrent pipeline runs allowed. Default 1, by policy: one expensive Bob
# subprocess at a time. Mode A (vision) runs are not limited by this.
ARCH2CODE_MAX_CONCURRENT_PIPELINE_RUNS=

# ---------------------------------------------------------------------------
# Server binding
# ---------------------------------------------------------------------------

# Bind address. Default 127.0.0.1. Bob's licence (clause 53d) forbids providing
# hosting or a commercial service to third parties, and this app ships no
# authentication and no CORS by design. Do not bind it to 0.0.0.0.
ARCH2CODE_HOST=

# Port. Default 8765.
ARCH2CODE_PORT=
