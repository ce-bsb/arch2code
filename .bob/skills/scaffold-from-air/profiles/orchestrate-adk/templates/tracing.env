# arch2code: generated from AIR {{run_id}} :: {{component_id}}
# source: {{source_artifact}}  evidence: {{evidence}}
# DO NOT EDIT BY HAND — regenerate via the arch-scaffold mode
#
# Observability for the agent — traces exporter. Turn it on with
#   orchestrate observability traces configure
# Langfuse ties the evaluation runs (evaluations/config.yaml langfuse_enabled)
# to live monitoring, so a red-teaming failure and a production incident show up
# in the same place. These are ENV VAR NAMES, not values: set the values per
# environment, never commit a key.

# Exporter: langfuse | otel
TRACES_EXPORTER=langfuse

# Langfuse (when TRACES_EXPORTER=langfuse) — set per environment, never here.
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# OpenTelemetry (when TRACES_EXPORTER=otel)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME={{otel_service_name}}
