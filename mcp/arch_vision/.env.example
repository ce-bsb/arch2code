# arch_vision — configuration
# Copy this to .env and fill it in. Do NOT commit .env.
#
# These variables are read by the MCP server process. Reference them in
# .bob/mcp.json via ${env:VAR} — never paste the key inside mcp.json, which goes
# into Git.

# --- watsonx.ai credentials (required for the vision path) --------------------
WATSONX_APIKEY=
WATSONX_PROJECT_ID=
# Alternative to PROJECT_ID when using a deployment space:
# WATSONX_SPACE_ID=

# --- Region ------------------------------------------------------------------
# us-south | eu-de | eu-gb | jp-tok | au-syd | ca-tor
# Check yours: the wrong region returns a project 404, not a region error.
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# --- Multimodal model --------------------------------------------------------
# DO NOT GUESS THE ID. Find out YOUR project's by actually testing:
#
#   python3 mcp/arch_vision/preflight.py --probe        # tests each model with an image
#   python3 mcp/arch_vision/preflight.py --probe --set  # writes the best one here
#
# Why probe instead of reading the name: a multimodal model does not always have
# "vision" in its id — llama-4-maverick is multimodal and does not. And being in
# the catalog does not guarantee that it accepts images. The only certainty is to
# send an image and see whether it answers.
#
# Preference for READING DIAGRAMS (IBM doc: the llama-4 models are natively
# multimodal, MoE with early fusion, optimized for visual recognition and image
# reasoning):
#   meta-llama/llama-4-maverick-17b-128e-instruct-fp8   128 experts; best for a dense diagram
#   meta-llama/llama-4-scout-17b-16e-instruct-fp8-dynamic  16 experts; lighter
#   mistralai/mistral-small-3-1-24b-instruct-2503       multimodal; simple diagrams
#
# Withdrawn from several projects (red icon in the catalog) — do not use:
#   meta-llama/llama-3-2-90b-vision-instruct
#   meta-llama/llama-3-2-11b-vision-instruct
WATSONX_VISION_MODEL_ID=meta-llama/llama-4-maverick-17b-128e-instruct-fp8
WATSONX_API_VERSION=2024-10-08

# --- Behavior ----------------------------------------------------------------
ARCH_INTAKE_INBOX=.arch/intake/inbox
ARCH_VISION_MAX_IMAGE_MB=5
ARCH_VISION_TIMEOUT=120
